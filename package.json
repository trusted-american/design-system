{
  "name": "@trusted-american/design-system",
  "version": "0.0.291",
  "description": "Components for building robust user interfaces.",
  "keywords": [
    "ember-addon"
  ],
  "repository": "https://github.com/trusted-american/design-system",
  "license": "MIT",
  "author": "Trusted American Insurance Agency",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./declarations/index.d.ts",
      "default": "./dist/index.js"
    },
    "./addon-main.js": "./addon-main.cjs",
    "./*.css": "./dist/*.css",
    "./*": {
      "types": "./declarations/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "addon-main.cjs",
    "declarations",
    "dist"
  ],
  "scripts": {
    "build": "rollup --config",
    "format": "prettier . --cache --write",
    "lint": "concurrently \":lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:fix": "concurrently \":lint:*:fix\" --names \"fix:\" --prefixColors auto &&  run format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint . --no-error-on-unmatched-pattern",
    "lint:hbs:fix": "ember-template-lint . --fix --no-error-on-unmatched-pattern",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "ember-tsc --noEmit",
    "prepack": "rollup --config",
    "start": "vite dev",
    "test": "vite build --mode=development --out-dir dist-tests && testem --file testem.cjs ci --port 0"
  },
  "dependencies": {
    "@babel/core": "^7.28.5",
    "@fortawesome/ember-fontawesome": "^3.1.0",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fullcalendar/core": "^6.1.19",
    "@fullcalendar/daygrid": "^6.1.19",
    "@fullcalendar/list": "^6.1.19",
    "@fullcalendar/timegrid": "^6.1.19",
    "@github/markdown-toolbar-element": "^2.2.3",
    "@tiptap/core": "^2.26.1",
    "@tiptap/pm": "^2.26.1",
    "@tiptap/starter-kit": "^2.26.1",
    "@types/bootstrap": "^5.2.10",
    "bootstrap": "^5.3.7",
    "change-case": "^5.4.4",
    "dayjs": "^1.11.18",
    "ember-auto-import": "^2.11.1",
    "ember-basic-dropdown": "^8.8.0",
    "ember-breadcrumb-trail": "^2.0.0",
    "ember-cli-babel": "^8.2.0",
    "ember-cli-htmlbars": "^6.3.0",
    "ember-cli-showdown": "^9.0.2",
    "ember-concurrency": "^5.1.0",
    "ember-file-upload": "^9.5.0",
    "ember-modifier": "^4.2.2",
    "ember-power-select": "^8.11.0",
    "ember-power-select-with-create": "^3.0.1",
    "ember-template-imports": "^4.3.0",
    "ember-truth-helpers": "^5.0.0",
    "ember-yeti-table": "^2.0.2",
    "identicon.js": "^2.3.3",
    "tracked-built-ins": "^4.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/eslint-parser": "^7.25.1",
    "@babel/plugin-transform-typescript": "^7.25.2",
    "@babel/runtime": "^7.25.6",
    "@ember/app-tsconfig": "^1.0.0",
    "@ember/library-tsconfig": "^1.0.0",
    "@ember/test-helpers": "^5.2.1",
    "@ember/test-waiters": "^4.1.1",
    "@embroider/addon-dev": "^8.1.0",
    "@embroider/compat": "^4.1.0",
    "@embroider/core": "^4.1.0",
    "@embroider/macros": "^1.18.0",
    "@embroider/vite": "^1.1.5",
    "@eslint/js": "^9.28.0",
    "@glimmer/component": "^2.0.0",
    "@glint/ember-tsc": "^1.0.3",
    "@glint/template": "^1.6.1",
    "@glint/tsserver-plugin": "^2.0.0",
    "@popperjs/core": "^2.11.8",
    "@rollup/plugin-babel": "^6.0.4",
    "@types/identicon.js": "^2.3.5",
    "@types/qunit": "^2.19.13",
    "babel-plugin-ember-template-compilation": "^2.2.5",
    "concurrently": "^9.2.1",
    "ember-code-snippet": "github:ef4/ember-code-snippet",
    "ember-page-title": "^9.0.3",
    "ember-qunit": "^9.0.4",
    "ember-shiki": "^0.3.0",
    "ember-source": "~6.5.0",
    "ember-strict-application-resolver": "^0.1.0",
    "ember-template-lint": "^7.9.3",
    "ember-test-selectors": "^7.1.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^12.7.4",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^17.23.1",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-ember-template-tag": "^2.1.0",
    "qunit": "^2.24.1",
    "qunit-dom": "^3.4.0",
    "rollup": "^4.22.5",
    "testem": "^3.15.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.1.9"
  },
  "overrides": {
    "@glimmer/component": "^2.0.0",
    "ember-cli-babel": "^8.2.0"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "version": 2,
    "type": "addon",
    "main": "addon-main.cjs"
  }
}
