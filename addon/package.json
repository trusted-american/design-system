{
  "name": "@trusted-american/design-system",
  "version": "0.0.292",
  "description": "Components for building robust user interfaces.",
  "keywords": [
    "ember-addon"
  ],
  "repository": "https://github.com/trusted-american/design-system",
  "license": "MIT",
  "author": "Trusted American Insurance Agency",
  "typesVersions": {
    "*": {
      "test-support": [
        "declarations/addon-test-support/index.d.ts"
      ],
      "test-support/*": [
        "declarations/addon-test-support/*",
        "declarations/addon-test-support/*/index.d.ts"
      ],
      "*": [
        "declarations/addon/*",
        "declarations/addon/*/index.d.ts"
      ]
    }
  },
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "dependencies": {
    "@embroider/addon-shim": "^1.10.2",
    "@fortawesome/ember-fontawesome": "^3.1.0",
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fullcalendar/core": "^6.1.19",
    "@fullcalendar/daygrid": "^6.1.19",
    "@fullcalendar/list": "^6.1.19",
    "@fullcalendar/timegrid": "^6.1.19",
    "@github/markdown-toolbar-element": "^2.2.3",
    "@tiptap/core": "^2.27.1",
    "@tiptap/pm": "^2.27.1",
    "@tiptap/starter-kit": "^2.27.1",
    "@types/bootstrap": "^5.2.10",
    "bootstrap": "^5.3.7",
    "change-case": "^5.4.4",
    "dayjs": "^1.11.19",
    "ember-basic-dropdown": "^8.8.0",
    "ember-breadcrumb-trail": "^2.0.0",
    "ember-cli-showdown": "^9.0.2",
    "ember-concurrency": "^5.1.0",
    "ember-file-upload": "^9.5.0",
    "ember-modifier": "^4.2.2",
    "ember-power-select": "^8.12.0",
    "ember-power-select-with-create": "^3.1.0",
    "ember-template-imports": "^4.3.0",
    "ember-truth-helpers": "^5.0.0",
    "ember-yeti-table": "^2.0.2",
    "identicon.js": "^2.3.3",
    "tracked-built-ins": "^4.0.0"
  },
  "peerDependencies": {
    "ember-source": ">= 4.0.0"
  },
  "engines": {
    "node": ">= 20.11"
  },
  "ember": {
    "edition": "octane"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@babel/plugin-transform-class-properties": "^7.27.1",
    "@embroider/addon-dev": "^8.1.0",
    "@rollup/plugin-babel": "^6.1.0",
    "rollup": "^4.53.3"
  },
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*",
    "./test-support": "./dist/test-support/index.js",
    "./addon-main.js": "./addon-main.js"
  },
  "files": [
    "addon-main.js",
    "dist"
  ],
  "scripts": {
    "build": "rollup --config",
    "prepublishOnly": "rollup --config",
    "start": "rollup --config --watch"
  },
  "ember-addon": {
    "main": "addon-main.js",
    "type": "addon",
    "version": 2
  }
}
